# Template for engine/.env — copy to `.env` and fill in real values.
# This file is committed (no secrets); the real `.env` is gitignored.
#
#   cp .env.example .env
#
# Google PageSpeed Insights API key (performance module). Optional in dev — the API works
# key-less at a low rate limit. https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Cloudflare (optional). Account ID is in your dashboard URL; token at
# dash.cloudflare.com/profile/api-tokens. The SAME token powers two features; grant the scopes
# for whichever you use:
#   - Browser Rendering (smart auto-render of JS/SPA pages):  Account -> Browser Rendering -> Edit
#   - Crawler-log connector (/crawlers "Connect Cloudflare"): Zone -> Zone -> Read
#                                                         and  Zone -> Analytics -> Read
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Scan history (optional). When set, /scan saves each scan and returns meta.diff (what changed
# vs the previous scan); also powers monitors + alerts. Unset = no persistence (stateless).
# Two backends behind one seam (store.py) — set ONE:
#
#   ASTOVA_DATABASE_URL  Postgres connection string (e.g. Supabase). DURABLE — survives
#                        redeploys, shared across workers. The production path. Needs the
#                        postgres extra: pip install -e ".[postgres]". Use the Supabase
#                        "Session pooler" / direct connection string (postgresql://...).
#   ASTOVA_DB_PATH       Path to a SQLite file. Good for local dev. NOTE: on an ephemeral
#                        container disk this resets on redeploy — not for production.
#
# If both are set, Postgres wins.
ASTOVA_DATABASE_URL=
ASTOVA_DB_PATH=
