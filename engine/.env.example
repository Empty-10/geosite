# Template for engine/.env — copy to `.env` and fill in real values.
# This file is committed (no secrets); the real `.env` is gitignored.
#
#   cp .env.example .env
#
# Google PageSpeed Insights API key (performance module). Optional in dev — the API works
# key-less at a low rate limit. https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
