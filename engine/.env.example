# Template for engine/.env — copy to `.env` and fill in real values.
# This file is committed (no secrets); the real `.env` is gitignored.
#
#   cp .env.example .env
#
# Google PageSpeed Insights API key (performance module). Optional in dev — the API works
# key-less at a low rate limit. https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Cloudflare (optional). Account ID is in your dashboard URL; token at
# dash.cloudflare.com/profile/api-tokens. The SAME token powers two features; grant the scopes
# for whichever you use:
#   - Browser Rendering (smart auto-render of JS/SPA pages):  Account -> Browser Rendering -> Edit
#   - Crawler-log connector (/crawlers "Connect Cloudflare"): Zone -> Zone -> Read
#                                                         and  Zone -> Analytics -> Read
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Scan history (optional) — path to a SQLite file. When set, /scan saves each scan and returns
# meta.diff (what changed vs the previous scan). Unset = no persistence (stateless). NOTE: on an
# ephemeral container disk this resets on redeploy; point it at a persistent disk for durable
# history (or swap store.py for Postgres later).
DAMASK_DB_PATH=
