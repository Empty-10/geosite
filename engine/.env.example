# Template for engine/.env — copy to `.env` and fill in real values.
# This file is committed (no secrets); the real `.env` is gitignored.
#
#   cp .env.example .env
#
# Google PageSpeed Insights API key (performance module). Optional in dev — the API works
# key-less at a low rate limit. https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Cloudflare Browser Rendering (optional) — renders JS/SPA pages so their content is
# scannable. Set BOTH to enable smart auto-render (only client-rendered shells trigger it;
# server-rendered sites like WordPress never do). Account ID is in your dashboard URL; create
# a token with Account -> Browser Rendering -> Edit at dash.cloudflare.com/profile/api-tokens.
CF_ACCOUNT_ID=
CF_API_TOKEN=
