# Web app environment — copy to .env.local and fill in real values.
# .env.local is gitignored; this template is committed and must stay secret-free.
#
#   cp .env.example .env.local
#
# Anthropic API key for AI-drafted fixes (POST /api/fix). Without it, the AI
# "Draft with AI" button is disabled and the endpoint returns "not configured".
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: model used for drafting. Defaults to claude-haiku-4-5 when unset.
ASTOVA_FIX_MODEL=

# AI visibility sampling (POST /api/visibility) queries whichever of these are set — add engines
# to widen "multi-engine" coverage + share of voice. Each engine needs its OWN key; they're
# independent. ANTHROPIC_API_KEY (above) powers Claude.
#   OPENAI_API_KEY      → "ChatGPT" (OpenAI Responses API + web search)
#   PERPLEXITY_API_KEY  → "Perplexity" (sonar)
#   GEMINI_API_KEY      → "Gemini" (google_search grounding)
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Optional: point /api/scan at a deployed engine service instead of shelling out
# to the local Python engine (production path). See web/README.md.
ASTOVA_ENGINE_URL=

# Supabase Auth (login/signup). Both are PUBLIC values, safe to expose to the browser.
# Find them in Supabase → Project Settings → API:
#   NEXT_PUBLIC_SUPABASE_URL       = the Project URL (https://<ref>.supabase.co)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  = the anon / publishable key
# When BOTH are unset the auth middleware no-ops and the marketing site runs unchanged.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
