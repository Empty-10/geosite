# Web app environment — copy to .env.local and fill in real values.
# .env.local is gitignored; this template is committed and must stay secret-free.
#
#   cp .env.example .env.local
#
# Anthropic API key for AI-drafted fixes (POST /api/fix). Without it, the AI
# "Draft with AI" button is disabled and the endpoint returns "not configured".
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: model used for drafting. Defaults to claude-haiku-4-5 when unset.
ASTOVA_FIX_MODEL=

# AI visibility sampling (POST /api/visibility) queries whichever of these are set — add engines
# to widen "multi-engine" coverage + share of voice. ANTHROPIC_API_KEY (above) powers Claude.
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Optional: point /api/scan at a deployed engine service instead of shelling out
# to the local Python engine (production path). See web/README.md.
ASTOVA_ENGINE_URL=
